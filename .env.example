# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Supabase (public — safe in client bundles) ───────────────────────────────
# Found in: Project Settings → API → Project URL and anon/public key
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>
VITE_SUPABASE_PROJECT_ID=<project-id>

# ── Supabase (secret — server-side only, never expose to client) ─────────────
# Found in: Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# ── Stripe (secret — server-side only) ───────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SANDBOX_API_KEY=sk_test_...
STRIPE_LIVE_API_KEY=sk_live_...
PAYMENTS_SANDBOX_WEBHOOK_SECRET=whsec_...
PAYMENTS_LIVE_WEBHOOK_SECRET=whsec_...

# ── Stripe (public — safe in client bundles) ─────────────────────────────────
# Publishable key (pk_test_ or pk_live_) — shown to clients
VITE_PAYMENTS_CLIENT_TOKEN=pk_test_...

# ── Lovable platform ─────────────────────────────────────────────────────────
# Required to proxy Stripe and AI requests through the Lovable gateway
LOVABLE_API_KEY=<lovable-api-key>

# ── Anthropic / AI features ──────────────────────────────────────────────────
# Required for AI-powered product guidelines and safety advice
ANTHROPIC_API_KEY=sk-ant-...

# ── Webhook authentication ────────────────────────────────────────────────────
# Shared secret used to authenticate Supabase → app webhook calls.
# Set the same value in Supabase → Database Hooks → HTTP Headers → x-hook-secret
HOOK_SECRET=<generate-a-random-secret>

# ── Expo push notifications (optional) ───────────────────────────────────────
# Required only if using Expo push notification delivery
EXPO_ACCESS_TOKEN=<expo-access-token>

# ── Development overrides ─────────────────────────────────────────────────────
# Set to true in .env.local to bypass Pro paywalls in development only
# VITE_FORCE_PRO=false
