# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Supabase (public — safe in client bundles) ───────────────────────────────
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>
VITE_SUPABASE_PROJECT_ID=<project-id>

# ── Supabase (secret — server-side only) ─────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# ── Stripe (secret — server-side only) ───────────────────────────────────────
STRIPE_SANDBOX_API_KEY=sk_test_...
STRIPE_LIVE_API_KEY=sk_live_...
PAYMENTS_SANDBOX_WEBHOOK_SECRET=whsec_...
PAYMENTS_LIVE_WEBHOOK_SECRET=whsec_...

# ── Stripe (public — safe in client bundles) ─────────────────────────────────
VITE_PAYMENTS_CLIENT_TOKEN=pk_test_...   # or pk_live_...

# ── Lovable platform ─────────────────────────────────────────────────────────
LOVABLE_API_KEY=<lovable-api-key>

# ── Expo push notifications (optional) ───────────────────────────────────────
EXPO_ACCESS_TOKEN=<expo-access-token>
